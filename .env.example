# ─── Database (Prisma Postgres / any Postgres URL) ────────────────
DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
DIRECT_DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# ─── Auth.js v5 ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_use_openssl_rand_base64_32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Set to "true" to enable a dev-only "Sign in as Dev User" button on /login.
# Leave unset / "false" in production.
DEV_AUTH_ENABLED="true"

# OAuth provider credentials (leave blank to hide that provider's button)
AUTH_TWITCH_ID=""
AUTH_TWITCH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ─── BYOK encryption ──────────────────────────────────────────────
# 32-byte key, base64 encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BYOK_ENCRYPTION_KEY="CHANGE_ME_base64_32_bytes_for_AES_256_GCM_replace_me_now_pls="

# Rotate this when changing keys; old data stays readable while you migrate.
BYOK_KEY_VERSION="1"

# ─── Audio ingest worker ──────────────────────────────────────────
# Used both for signing JWTs the browser carries to the worker, and
# for the worker → web app /api/worker/* internal calls.
WORKER_SHARED_SECRET="CHANGE_ME_base64_32_bytes_distinct_from_AUTH_SECRET_xx="

# Public URL the streamer's browser uses to open a WS to the worker.
NEXT_PUBLIC_WORKER_WS_URL="ws://localhost:8787"
NEXT_PUBLIC_WORKER_HTTP_URL="http://localhost:8787"

# Worker-side: where the web app lives (for /api/worker/keys/fetch callbacks).
WEB_APP_URL="http://localhost:3000"

# Worker-side: which port to listen on.
WORKER_PORT="8787"

# ─── Rate limiting (Upstash Redis) ────────────────────────────────
# Leave blank for an in-memory fallback (dev only).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Optional: IP-hash salt rotation ──────────────────────────────
# Used to hash IPs in AuditLog without storing raw IPs.
# Rotate monthly in prod.
AUDIT_IP_SALT="rotate-me-monthly"
